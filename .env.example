# ─────────────────────────────────────────────────────────────────────────────
# WiFi Channel Optimizer — environment configuration
# Copy this file to ".env" and fill in your values.
# NEVER commit ".env" to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Router admin credentials
ROUTER_URL=http://192.168.100.1
ROUTER_USER=admin
ROUTER_PASS=admin

# Router driver — selects the automation implementation for your router model.
# Available built-in drivers:
#   huawei_hg8145x6   (default) — Huawei HG8145X6, tested with Entel ISP Chile
# To add a new model: subclass BaseRouter in wifi_optimizer/routers/<model>.py
# and register it in the ROUTER_DRIVERS dict in main.py.
ROUTER_DRIVER=huawei_hg8145x6

# Scanning & daemon
# How often to re-scan the RF environment (seconds). Cheap — only runs netsh, no router contact.
SCAN_INTERVAL_SECONDS=300

# Minimum time between actual router channel changes (seconds).
# Scanning happens every SCAN_INTERVAL_SECONDS but a change can only be applied
# once this cooldown has elapsed since the last one. Prevents hammering the router.
# Default: 3600 (1 hour).
CHANGE_COOLDOWN_SECONDS=3600

# Minimum relative improvement required to trigger a channel change.
# 0.40 = 40% — only switch if the new channel is dramatically less congested.
# Lower values (e.g. 0.20) react faster but risk unnecessary radio restarts.
HYSTERESIS_THRESHOLD=0.40

# ── Post-change quality monitoring (gaming-tuned defaults) ───────────────────
# How long to wait after a channel change before evaluating quality (seconds).
# 5 min is enough for the radio to stabilize without ruining a full match.
TRIAL_PERIOD_SECONDS=300

# Gateway RTT increase (ms) that triggers a channel revert.
# Measures the Wi-Fi hop only (ping to 192.168.100.1), not the full internet path.
# 20 ms is noticeable in competitive gaming (target: <5 ms to gateway).
PING_DEGRADATION_MS=20

# Jitter increase (ms) that triggers a revert.
# Jitter = std-dev of individual RTT samples. More harmful than high-but-stable ping.
# 15 ms of extra jitter will cause rubber-banding and packet loss in most games.
JITTER_DEGRADATION_MS=15

# Download speed drop fraction that triggers a revert (secondary signal).
# Not directly relevant to gaming latency; kept as a safety net.
SPEED_DEGRADATION_PCT=0.40
